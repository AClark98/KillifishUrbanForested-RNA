# Run variance stabilizing transformation
vsd <- vst(GFKdds, blind=FALSE)
vst_counts <- assay(vsd)


###########Frontloading

##Define home for both populations

# Long Bayou = long_bayou_F, home "control" treatment = tide
LB_control_samples <- colnames(GFKdds)[
  GFKdds$origin == "long_bayou_F" & GFKdds$treatment == "tide"
]

# Weakley Bayou = weakley_bayou_U, home treatment = tide_runoff
WB_control_samples <- colnames(GFKdds)[
  GFKdds$origin == "weakley_bayou_U" & GFKdds$treatment == "tide_runoff"
]

# Expression of LB stress induced genes in WB home: WB frontloading
WB_frontloaded <- rowMeans(vst_counts[backloaded_for_LB, WB_control_samples, drop=FALSE])

# Expression of WB stress induced genes in LB home: LB frontloading
LB_frontloaded <- rowMeans(vst_counts[backloaded_for_WB, LB_control_samples, drop=FALSE])

summary(WB_frontloaded)
  #Min. 1st Qu.  Median    Mean 3rd Qu.    Max. 
  #7.167   7.433   7.698   8.484   9.142  10.587 

summary(LB_frontloaded)
  #Min. 1st Qu.  Median    Mean 3rd Qu.    Max. 
  #7.417   7.672   8.195   8.625   9.680  10.673


# Mean frontloaded expression relative to own home
LB_home_expr <- rowMeans(vst_counts[backloaded_for_LB, LB_control_samples, drop=FALSE])
WB_home_expr <- rowMeans(vst_counts[backloaded_for_WB, WB_control_samples, drop=FALSE])

frontload_ratio_WB <- mean(WB_frontloaded) / mean(LB_home_expr)
frontload_ratio_LB <- mean(LB_frontloaded) / mean(WB_home_expr)

frontload_ratio_WB
