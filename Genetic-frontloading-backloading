#####THIS TAKES PLACE IMMEDIATELY AFTER RUNNING DESEQ2 to get differentially expressed genes based on origin (origin + ~ treatment), treatment (~ origin + treatment), and origin+treatment (~1)
setwd("~/Library/CloudStorage/Box-Box/Bernal_lab/Antrelle/GulfKillifish")

library(VennDiagram)
library(gplots)


#Define "control" and "experimental" conditions (this is not a code; just so that you know what is the control and experimental treatment for each population):
#long_bayou_F control conditions: long_bayou_F:tide
#long_bayou_F experimental conditions: long_bayou_F:tide_runoff
#weakley_bayou_U control conditions: weakley_bayou_U:tide_runoff
#weakley_bayou_U experimental conditions: weakley_bayou_U:tide


###########BACKLOADING############ #what genes are significantly turned on in response to new stressor or environment

#Subset data based on origin to determine effect of treatment

##### Long Bayou population
LB_dds <- GFKdds[, GFKdds$origin == "long_bayou_F"]
design(LB_dds) <- ~ treatment
LB_dds <- DESeq(LB_dds)
LB_treatmentinduced <- results(LB_dds, contrast = c("treatment", "tide_runoff", "tide"))  # foreign vs home


# Get significantly upregulated genes (turned-on)
backloaded_LB <- subset(LB_treatmentinduced, padj < 0.05 & log2FoldChange > 1) #the >1 means that the genes change expression (backloaded)
backloaded_for_LB <- rownames(backloaded_LB)

#View backloaded genes for LB
backloaded_for_LB
    #[1] "gene:ENSFHEG00000016601" "gene:ENSFHEG00000006314" "gene:ENSFHEG00000008149"


##### Weakley Bayou population
WB_dds <- GFKdds[, GFKdds$origin == "weakley_bayou_U"]
design(WB_dds) <- ~ treatment
WB_dds <- DESeq(WB_dds)
WB_treatmentinduced <- results(WB_dds, contrast = c("treatment", "tide", "tide_runoff"))  # foreign vs home


# Get significantly upregulated genes (treatment-induced)
backloaded_WB <- subset(WB_treatmentinduced, padj < 0.05 & log2FoldChange > 1)
backloaded_for_WB <- rownames(backloaded_WB)

#View backloaded genes for WB
backloaded_for_WB
    #[1] "gene:ENSFHEG00000019924" "gene:ENSFHEG00000017456" "gene:ENSFHEG00000009196"
    #[4] "gene:ENSFHEG00000009502" "gene:ENSFHEG00000003544" "gene:ENSFHEG00000015691"
    #[7] "gene:ENSFHEG00000009231" "gene:ENSFHEG00000003293" "gene:ENSFHEG00000012294"
    #[10] "gene:ENSFHEG00000012277" "gene:ENSFHEG00000009823" "gene:ENSFHEG00000007932"
    #[13] "gene:ENSFHEG00000000626" "gene:ENSFHEG00000013510" "gene:ENSFHEG00000009514"
    #[16] "gene:ENSFHEG00000023008"

  #I now have the gene lists for LB (backloaded_for_LB) and WB (backloaded_for_WB) to identify candidate genes for frontloading by
  #testing for equal or higerh expression of those genes in the opposite population


# Run variance stabilizing transformation
vsd <- vst(GFKdds, blind=FALSE)
vst_counts <- assay(vsd)


###########Frontloading

##Define home for both populations

# Long Bayou = long_bayou_F, home "control" treatment = tide
LB_control_samples <- colnames(GFKdds)[
  GFKdds$origin == "long_bayou_F" & GFKdds$treatment == "tide"
]

# Weakley Bayou = weakley_bayou_U, home treatment = tide_runoff
WB_control_samples <- colnames(GFKdds)[
  GFKdds$origin == "weakley_bayou_U" & GFKdds$treatment == "tide_runoff"
]

# Expression of LB stress induced genes in WB home: WB frontloading
WB_frontloaded <- rowMeans(vst_counts[backloaded_for_LB, WB_control_samples, drop=FALSE])

# Expression of WB stress induced genes in LB home: LB frontloading
LB_frontloaded <- rowMeans(vst_counts[backloaded_for_WB, LB_control_samples, drop=FALSE])

summary(WB_frontloaded)
  #Min. 1st Qu.  Median    Mean 3rd Qu.    Max. 
  #7.167   7.433   7.698   8.484   9.142  10.587 

summary(LB_frontloaded)
  #Min. 1st Qu.  Median    Mean 3rd Qu.    Max. 
  #7.417   7.672   8.195   8.625   9.680  10.673


# Mean frontloaded expression relative to own home
LB_home_expr <- rowMeans(vst_counts[backloaded_for_LB, LB_control_samples, drop=FALSE])        #for each gene that was backloaded in LB, what's its mean expression in LB control (tide)?
WB_home_expr <- rowMeans(vst_counts[backloaded_for_WB, WB_control_samples, drop=FALSE])        #for each gene that was backloaded in WB, what's its mean expression in WB control (tide+runoff)?

frontload_ratio_WB <- mean(WB_frontloaded) / mean(LB_home_expr)
frontload_ratio_LB <- mean(LB_frontloaded) / mean(WB_home_expr)

frontload_ratio_WB
  #[1] 1.059625
frontload_ratio_LB
  #[1] 1.059798
                        #this means that each pop has similar expression patterns; no strong frontloading

########Visualizing frontloading/backloading on a boxplot

#Calculating own population home expression (backloading reference)
LB_home_expr <- rowMeans(vst_counts[backloaded_for_LB, LB_control_samples, drop=FALSE])
WB_home_expr <- rowMeans(vst_counts[backloaded_for_WB, WB_control_samples, drop=FALSE])

#Cross-population frontloading; calculating level of expression in opposite population
LB_frontloaded_in_WB <- rowMeans(vst_counts[backloaded_for_LB, WB_control_samples, drop=FALSE])
WB_frontloaded_in_LB <- rowMeans(vst_counts[backloaded_for_WB, LB_control_samples, drop=FALSE])

# Combine for boxplot
expr_matrix <- list(
  "LB home" = LB_home_expr,                                                #LB home expression
  "LB in WB" = LB_frontloaded_in_WB,                                       #WB frontloaded;are these LB backloaded genes frontloaded in WB?
  "WB home" = WB_home_expr,                                                #WB home expression
  "WB in LB" = WB_frontloaded_in_LB                                        #LB frontloaded;#are these WB backloaded genes frontloaded in LB?
)

# Boxplot
boxplot(
  expr_matrix,
  col = c("skyblue","lightblue","salmon","pink"),
  ylab = "VST expression",
  main = "Frontloading and Backloading Comparison",                        
  outline = FALSE
)

# Add median lines in a different color (optional)
abline(h = median(LB_home_expr), col = "blue", lty = 2)
abline(h = median(WB_home_expr), col = "red", lty = 2)


